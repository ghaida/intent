---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { loadShowcase } from '../lib/showcase';

const showcase = loadShowcase();
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<Base title="How to Use — Intent" description={`Follow ${showcase.name} — ${showcase.tagline.toLowerCase()} — through every Intent skill, from first question to engineering handoff.`}>
  <div class="page">
    <!-- Hero -->
    <section class="how-to-use-hero" aria-labelledby="how-to-use-heading">
      <h1 id="how-to-use-heading">How to Use</h1>
      <p class="subtext muted">
        Follow one project through every Intent skill — from first question to engineering handoff.
      </p>
      <div class="showcase-premise">
        <strong>The project: {showcase.name}</strong> — {showcase.tagline}
      </div>
    </section>

    <!-- Skill chapters -->
    {showcase.steps.map((step, i) => (
      <>
        <section class="section" aria-labelledby={`step-${step.skill}`}>
          <SectionLabel
            label={`/${step.skill}`.toUpperCase()}
            annotation={step.agent}
          />
          <div class="section-content">
            <h2 id={`step-${step.skill}`} class="visually-hidden">{step.skill}</h2>
            <p class="step-summary">{step.summary}</p>
            <p class="step-narrative">{step.narrative}</p>
            {step.output && (
              <details>
                <summary>
                  <span class="step-output-label">See what <code class="mono">/{step.skill}</code> produced</span>
                </summary>
                <div class="details-content step-output" set:html={step.output} />
              </details>
            )}
          </div>
        </section>

        {step.philosopher && (
          <div class="philosopher-callout">
            <span class="philosopher-label mono">/philosopher</span>
            <div set:html={step.philosopher} />
          </div>
        )}
      </>
    ))}

    <!-- Closing CTA -->
    <section class="section" aria-labelledby="get-started-heading">
      <SectionLabel label="GET STARTED" annotation="Install Intent" icon="terminal" />
      <div class="section-content">
        <h2 id="get-started-heading" class="visually-hidden">Get Started</h2>
        <p class="step-narrative">
          This is what Intent does for every project. Fifteen skills, six agents, one cohesive design practice.
        </p>
        <div class="code-block">
          <span class="code-block-hint">All platforms</span>
          <div class="code-block-row">
            <code>npx skills add ghaida/intent --all</code>
            <button class="code-copy" type="button" aria-label="Copy to clipboard" data-copy="npx skills add ghaida/intent --all">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </button>
          </div>
          <span class="code-block-followup muted small mono">Works with Cursor, Claude Code, Codex CLI, and more</span>
        </div>
        <p class="section-footer muted small">
          <a href={`${base}skills/`} class="link">Browse all skills →</a>
        </p>
      </div>
    </section>
  </div>
</Base>
