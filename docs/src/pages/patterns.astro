---
import Base from '../layouts/Base.astro';
import { loadPatterns, allPatterns, patternStats } from '../lib/patterns';

const categories = loadPatterns();
const patterns = allPatterns(categories);
const stats = patternStats(categories);
---

<Base title="Anti-Pattern Catalog — Intent" description={`${stats.total} named UX anti-patterns across ${stats.categories} categories. Deceptive design, dark patterns, and common UX failures — identified, categorized, and rated by severity.`}>
  <div class="page">
    <section class="patterns-hero" aria-labelledby="patterns-heading">
      <h1 id="patterns-heading">Anti-Pattern Catalog</h1>
      <p class="subtext muted">
        {stats.total} named patterns across {stats.categories} categories.
        Deceptive design, addictive mechanics, accessibility weaponization,
        and common UX failures. Each one identified, categorized, and rated.
      </p>
    </section>

    <!-- Filter Tabs -->
    <h2 id="catalog-heading" class="visually-hidden">Pattern catalog</h2>
    <div class="filter-tabs" aria-label="Filter by category">
      <button
        class="filter-tab active"
        role="button"
        aria-pressed="true"
        data-category="all"
      >
        All ({stats.total})
      </button>
      {categories.map((cat) => (
        <button
          class="filter-tab"
          role="button"
          aria-pressed="false"
          data-category={cat.slug}
        >
          {cat.name} ({cat.patterns.length})
        </button>
      ))}
    </div>

    <!-- Pattern Table -->
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Pattern</th>
            <th class="col-severity">Severity</th>
            <th>Description</th>
            <th class="hide-mobile col-category">Category</th>
          </tr>
        </thead>
        <tbody>
          {patterns.map((p) => (
            <tr data-category={p.categorySlug}>
              <td class="pattern-name">{p.name}</td>
              <td>
                <span class={`severity severity--${p.severity.toLowerCase()}`}>
                  {p.severity}
                </span>
              </td>
              <td class="pattern-desc muted">{p.description}</td>
              <td class="hide-mobile">
                <span class="pattern-cat mono small muted">{p.category}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Base>

<script is:inline src="/js/pattern-filter.js"></script>
