---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { loadSkills, groupByCategory } from '../lib/skills';
import { loadPatterns, patternStats } from '../lib/patterns';

const skills = loadSkills();
const categories = groupByCategory(skills);
const patternCategories = loadPatterns();
const pStats = patternStats(patternCategories);

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';

// Sample patterns for preview (mix of severities)
const samplePatterns = [
  patternCategories.flatMap(c => c.patterns).find(p => p.name === 'Bait and Switch'),
  patternCategories.flatMap(c => c.patterns).find(p => p.name === 'Fake Countdown Timers'),
  patternCategories.flatMap(c => c.patterns).find(p => p.name === 'Infinite Scroll'),
  patternCategories.flatMap(c => c.patterns).find(p => p.name === 'Anthropomorphic Manipulation'),
  patternCategories.flatMap(c => c.patterns).find(p => p.name === 'Prechecked Consent'),
  patternCategories.flatMap(c => c.patterns).find(p => p.name === 'Dead Ends'),
].filter(Boolean);

const principles = [
  { title: 'The problem comes first', desc: 'Frame the problem before diving into a solution. Understand the audience and shape products that solve their problems within defined constraints.' },
  { title: 'Protect user autonomy', desc: 'Dark patterns exploit psychological vulnerabilities to make people act against their own interests, and erode your users\u2019 relationship with the product.' },
  { title: 'Ground decisions in evidence', desc: 'Understanding your users and your business is an ongoing practice of curiosity that guides product decisions toward better alignment between user needs and business goals.' },
  { title: 'Systems over screens', desc: 'The purpose of a system is what it does. Start with intended outcomes and shape systems that enable those outcomes.' },
  { title: 'Design for everyone', desc: 'A billion people worldwide have a disability. Accessible design makes products work better for everyone.' },
  { title: 'Measure what matters', desc: 'Define what success looks like for your users and the business. Great success metrics align business and user goals and help shape future iterations.' },
];
---

<Base title="Design with Intent">
  <div class="page">
    <!-- Hero -->
    <section class="hero" aria-labelledby="hero-heading">
      <h1 id="hero-heading">
        Design with <span class="hero-accent">Intent</span>
      </h1>
      <p class="hero-lede subtext">
        A UX strategy system for AI tools. {skills.length} skills covering research,
        strategy, flows, content, accessibility, ethics, and measurement.
      </p>
      <div class="hero-install-group">
        <div class="code-block hero-install">
          <span class="code-block-hint">Claude Code</span>
          <code>claude install-skill ghaida/intent</code>
        </div>
        <p class="hero-platforms muted small mono">
          Also available for <a href="#install" class="link">Cursor, VS Code Copilot, and manual install</a>
        </p>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="section" aria-labelledby="philosophy-heading">
      <SectionLabel label="PHILOSOPHY" annotation="Core thesis" icon="brain" />
      <div class="section-content">
        <h2 id="philosophy-heading" class="visually-hidden">Philosophy</h2>
        <p class="lead">
          Every design decision should have a reason.
        </p>
        <p class="philosophy-body">
          Design intent comes from curiosity about the people who will use your products and clarity about what the business needs. The best design decisions live where those two things align.
        </p>
      </div>
    </section>

    <!-- Principles -->
    <section class="section" aria-labelledby="principles-heading">
      <SectionLabel label="PRINCIPLES" annotation="6 core positions" icon="shield" />
      <div class="section-content">
        <h2 id="principles-heading" class="visually-hidden">Principles</h2>
        <div class="principles-grid">
          {principles.map((p) => (
            <div class="principle">
              <h3 class="principle-title">{p.title}</h3>
              <p class="principle-desc muted">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="section" aria-labelledby="skills-heading">
      <SectionLabel label={`${skills.length} SKILLS`} annotation="7 categories" icon="grid" />
      <div class="section-content">
        <h2 id="skills-heading" class="visually-hidden">Skills</h2>
        <div class="skill-categories">
          {categories.map((cat) => (
            <div class="skill-category">
              <span class="skill-category-label mono">{cat.label}</span>
              <div class="skill-category-tags">
                {cat.skills.map((s) => (
                  <a href={`${base}skills/#${s.slug}`} class="skill-tag">/{s.slug}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
        <p class="section-footer muted small">
          <a href={`${base}skills/`} class="link">View all skills with details →</a>
        </p>
      </div>
    </section>

    <!-- Anti-Patterns -->
    <section class="section" aria-labelledby="patterns-heading">
      <SectionLabel
        label="ANTI-PATTERNS"
        annotation={`${pStats.categories} categories · ${pStats.total}+ patterns`}
        icon="warning"
      />
      <div class="section-content">
        <h2 id="patterns-heading" class="visually-hidden">Anti-Patterns</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Pattern</th>
                <th>Severity</th>
                <th class="hide-mobile">Category</th>
              </tr>
            </thead>
            <tbody>
              {samplePatterns.map((p) => (
                <tr>
                  <td>{p!.name}</td>
                  <td>
                    <span class={`severity severity--${p!.severity.toLowerCase()}`}>
                      {p!.severity}
                    </span>
                  </td>
                  <td class="hide-mobile muted small">{p!.category}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="section-footer muted small">
          <a href={`${base}patterns/`} class="link">Browse all anti-patterns →</a>
        </p>
      </div>
    </section>

    <!-- Install -->
    <section class="section" id="install" aria-labelledby="install-heading">
      <SectionLabel label="INSTALL" annotation="4 platforms" icon="terminal" />
      <div class="section-content">
        <h2 id="install-heading" class="visually-hidden">Install</h2>
        <div class="install-methods">
          <div class="install-method">
            <h3 class="install-method-name mono">Claude Code</h3>
            <div class="code-block">
              <code>claude install-skill ghaida/intent</code>
            </div>
          </div>
          <div class="install-method">
            <h3 class="install-method-name mono">Cursor</h3>
            <p class="muted">
              Download the <a href="https://github.com/ghaida/intent/releases" class="link">.cursor rules</a> and add to your project's <code class="mono">.cursor/rules/</code> directory.
            </p>
          </div>
          <div class="install-method">
            <h3 class="install-method-name mono">VS Code Copilot</h3>
            <p class="muted">
              Download the <a href="https://github.com/ghaida/intent/releases" class="link">copilot instructions</a> and add to <code class="mono">.github/copilot/</code>.
            </p>
          </div>
          <div class="install-method">
            <h3 class="install-method-name mono">Manual</h3>
            <p class="muted">
              Clone the repo and copy <code class="mono">skills/</code> into your project. Each skill is a standalone markdown file.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Base>
