---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { loadSkills, groupByCategory } from '../lib/skills';

const allSkills = loadSkills();
const categories = groupByCategory(allSkills);
const skillCount = allSkills.length;
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<Base title="Skills — Intent" description={`${skillCount} specialized UX design skills organized by discipline. Each skill represents deep expertise in a distinct area of product design.`}>
  <div class="page">
    <section class="skills-hero" aria-labelledby="skills-heading">
      <h1 id="skills-heading">Skills</h1>
      <p class="subtext muted">
        {skillCount} skills organized by discipline. Each one carries real methodology
        for a distinct area of product design.
      </p>
    </section>

    {categories.map((cat) => (
      <section class="section" aria-labelledby={`cat-${cat.skills[0].category.toLowerCase().replace(/\s+/g, '-')}`}>
        <div class="section-label" aria-hidden="true">
          <span class="skill-cat-label">{cat.label}</span>
          <span class="section-label-annotation">{cat.skills.length} {cat.skills.length === 1 ? 'skill' : 'skills'}</span>
        </div>
        <div class="section-content">
          <h2
            id={`cat-${cat.skills[0].category.toLowerCase().replace(/\s+/g, '-')}`}
            class="visually-hidden"
          >
            {cat.label}
          </h2>

          {cat.skills.map((skill) => (
            <details id={skill.slug}>
              <summary>
                <div class="skill-header">
                  <h3 class="skill-name">/{skill.slug}</h3>
                  <p class="skill-desc muted">{skill.description}</p>
                </div>
              </summary>
              <div class="details-content">
                {skill.overview && (
                  <div class="skill-detail">
                    <span class="skill-detail-label mono muted">What it does</span>
                    <p>{skill.overview}</p>
                  </div>
                )}
                {skill.triggers && (
                  <div class="skill-detail">
                    <span class="skill-detail-label mono muted">When to use it</span>
                    <p>{skill.triggers}</p>
                  </div>
                )}
              </div>
            </details>
          ))}
        </div>
      </section>
    ))}

    <!-- Install -->
    <section class="section" id="install" aria-labelledby="install-heading">
      <SectionLabel label="INSTALL" annotation="3 methods" icon="terminal" />
      <div class="section-content">
        <h2 id="install-heading" class="visually-hidden">Install</h2>
        <div class="install-methods">
          <div class="install-method">
            <h3 class="install-method-name mono">All platforms</h3>
            <div class="code-block">
              <div class="code-block-row">
                <code>npx skills add ghaida/intent --all</code>
                <button class="code-copy" type="button" aria-label="Copy to clipboard" data-copy="npx skills add ghaida/intent --all">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
              <span class="code-block-followup muted small mono">Works with Cursor, Claude Code, Codex CLI, and more</span>
            </div>
          </div>
          <div class="install-method">
            <h3 class="install-method-name mono">Claude Code plugin</h3>
            <div class="code-block">
              <div class="code-block-row">
                <code>/plugin marketplace add ghaida/intent</code>
                <button class="code-copy" type="button" aria-label="Copy to clipboard" data-copy="/plugin marketplace add ghaida/intent">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
              <span class="code-block-followup muted small mono">Then open <code class="mono">/plugin</code> in Claude Code</span>
            </div>
          </div>
          <div class="install-method">
            <h3 class="install-method-name mono">Manual download</h3>
            <div class="install-downloads">
              <a href="https://github.com/ghaida/intent/releases/latest" class="install-download-link link mono" target="_blank" rel="noopener noreferrer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                All releases
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Base>
