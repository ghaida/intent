---
interface Props {
  label: string;
  annotation?: string;
  icon?: string;
}

const { label, annotation, icon } = Astro.props;

const icons: Record<string, string> = {
  brain: '<circle cx="12" cy="12" r="3"/><path d="M12 2a4.09 4.09 0 0 0-1 .06 3.9 3.9 0 0 0-2.78 2.78A4.09 4.09 0 0 0 8 6a3.9 3.9 0 0 0-3.16 1.84A4.05 4.05 0 0 0 4 10a3.9 3.9 0 0 0-.94 3.61A4 4 0 0 0 4 16a3.9 3.9 0 0 0 .84 3.16A4.09 4.09 0 0 0 6 20a3.9 3.9 0 0 0 2.78 2.78A4.09 4.09 0 0 0 10 23a3.9 3.9 0 0 0 3.16-.84A4.09 4.09 0 0 0 14 23a3.9 3.9 0 0 0 2.78-2.78A4.09 4.09 0 0 0 18 20a3.9 3.9 0 0 0 2.78-2.78A4.09 4.09 0 0 0 21 16a3.9 3.9 0 0 0 .94-3.61A4 4 0 0 0 21 10a3.9 3.9 0 0 0-.84-3.16A4.09 4.09 0 0 0 19 6a3.9 3.9 0 0 0-2.78-2.78A4.09 4.09 0 0 0 15 3a3.9 3.9 0 0 0-3-1z"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  grid: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>',
  warning: '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
};

const iconSvg = icon && icons[icon] ? icons[icon] : null;
---

<div class="section-label" aria-hidden="true">
  {iconSvg && (
    <span class="section-label__icon">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconSvg} />
      <span>{label}</span>
    </span>
  )}
  {!iconSvg && <span>{label}</span>}
  {annotation && <span class="section-label__annotation">{annotation}</span>}
</div>
