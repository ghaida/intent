  }

  .footer__license {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--blueprint-mark);
    letter-spacing: 0.04em;
  }

  .footer__github {
    font-size: var(--text-xs);
    font-weight: 500;
  }
